# Optional: semicolon-separated roots that contain SKILL.md files.
# Copy this file to .env.local and edit the paths for your machine.
# If unset, SkillWeaver scans common Codex/agent skill folders under your home directory.
#
# PowerShell one-off equivalent:
# $env:SKILLWEAVER_SKILL_ROOTS="$HOME\.codex\skills;$HOME\.codex\skills\.system;C:\path\to\your\skills"

SKILLWEAVER_SKILL_ROOTS=
